def _ps_json() -> List[Dict[str, Any]]:
    try:
        cmd = ["powershell", "-NoProfile", "-Command", "Get-CimInstance Win32_Process | Select-Object ProcessId, Name, CommandLine, CreationDate | ConvertTo-Json"]
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        if not res.stdout.strip(): return []
        data = json.loads(res.stdout)
        return data if isinstance(data, list) else [data]
    except Exception: return []

def _list_browser_procs() -> List[Dict[str, Any]]:
    all_ps = _ps_json()
    browsers = []
    for p in all_ps:
        name = (p.get("Name") or "").lower()
        cmd = (p.get("CommandLine") or "").lower()
        if "chrome.exe" in name or "msedge.exe" in name or "brave.exe" in name:
            browsers.append(p)
    return browsers

def _detect_rc1(procs: List[Dict[str, Any]]) -> Dict[str, Any]:
    for p in procs:
        cmd = (p.get("CommandLine") or "").lower()
        if "ungoogled-chromium" in cmd:
            return {"status": "running", "pid": p.get("ProcessId")}
    return {"status": "idle"}

def _detect_rc2(procs: List[Dict[str, Any]]) -> Dict[str, Any]:
    for p in procs:
        cmd = (p.get("CommandLine") or "").lower()
        if "bolt" in cmd or "porttoretro" in cmd:
            return {"status": "running", "pid": p.get("ProcessId")}
    return {"status": "idle"}

