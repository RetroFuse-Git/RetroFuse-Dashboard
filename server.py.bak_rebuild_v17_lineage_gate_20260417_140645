# ----------------------------------------------------------------------------
# Backend Helpers
# ----------------------------------------------------------------------------

def _read_json(path: Path) -> Optional[Any]:
    try:
        if not path.exists(): return None
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception: return None

def _read_markdown_kv(path: Path) -> Dict[str, str]:
    if not path.exists(): return {}
    out: Dict[str, str] = {}
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
        for line in content.splitlines():
            m = re.match(r"^\-\s+([^:]+):\s*(.*)$", line)
            if m: out[m.group(1).strip()] = m.group(2)
    except Exception: pass
    return out

def _safe_stat_mtime(path: Path) -> float:
    try:
        return path.stat().st_mtime
    except Exception:
        return 0.0

def _derive_bolt_boot_status() -> Tuple[str, str]:
    """
    Derives boot status from release-gate lineage artifacts.
    Expected Lineage = {controller_pid}|{runtime_verified_utc}|{current_target_id}
    """
    if not BOLT_STATE.exists() or not BOLT_STARTUP_RECEIPT.exists() or not BOLT_PROVENANCE.exists():
        return "UNKNOWN", "Missing required startup artifacts."

    try:
        # 1. Derive Expected Lineage from Controller State
        state = _read_json(BOLT_STATE) or {}
        c_pid = state.get("controller_pid")
        c_rv = state.get("runtime_verified_utc")
        c_tid = state.get("current_target_id")
        
        if not all([c_pid, c_rv, c_tid]):
            return "UNKNOWN", "Incomplete lineage fields in state."
        
        expected_lineage = f"{c_pid}|{c_rv}|{c_tid}"

        # 2. Extract Session from Receipt
        receipt_kv = _read_markdown_kv(BOLT_STARTUP_RECEIPT)
        receipt_session = receipt_kv.get("startup_session_id")
        if not receipt_session:
            return "UNKNOWN", "Missing startup_session_id in receipt."

        # 3. Extract Session from Latest Written Provenance Entry
        prov_session = None
        with open(BOLT_PROVENANCE, "r", encoding="utf-8") as f:
            for line in reversed(list(f)):
                line = line.strip()
                if not line: continue
                try:
                    entry = json.loads(line)
                    if entry.get("phase") == "receipt" and entry.get("status") == "written":
                        prov_session = entry.get("startup_session_id")
                        break
                except json.JSONDecodeError:
                    continue
        
        if not prov_session:
            return "UNKNOWN", "No valid provenance receipt found."

        # 4. Verification Gate (Triple-Match)
        if expected_lineage == receipt_session == prov_session:
            return "STRICT_CLEAN", "Lineage verified across artifacts."
        
        return "ARTIFACT_DRIFT", "Controller/receipt/provenance session mismatch."

    except Exception as e:
        return "UNKNOWN", f"Lineage error: {str(e)}"

# ----------------------------------------------------------------------------
# Telemetry Helpers
