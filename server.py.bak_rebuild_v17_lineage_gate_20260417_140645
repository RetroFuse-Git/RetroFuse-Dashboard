def _get_latest_signals() -> Dict[str, Any]:
    return _read_json(OPS_SIGNALS_JSON) or {}

def _get_alpha_stats() -> Dict[str, Any]:
    if not ALPHA_RAW_DIR.exists(): return {"count": 0}
    files = list(ALPHA_RAW_DIR.glob("*"))
    return {"count": len(files), "latest": max([f.stat().st_mtime for f in files]) if files else 0}

def _get_safepoint_stats() -> List[Dict[str, Any]]:
    stats = []
    for root in ARCHIVE_ROOTS:
        if root.exists():
            stats.append({"path": str(root), "count": len(list(root.glob("*")))})
    return stats

# ----------------------------------------------------------------------------
# Bolt Domain Logic
# ----------------------------------------------------------------------------

def _bolt_controller_state() -> Dict[str, Any]:
    state = _read_json(BOLT_STATE) or {}
    lock = _read_json(BOLT_LOCK)
    if isinstance(lock, dict):
        state["lock"] = lock
    return state

def _bolt_recent_cmdlog(n: int) -> List[Dict[str, Any]]:
    if not BOLT_CMDLOG.exists(): return []
    try:
        lines = BOLT_CMDLOG.read_text(encoding="utf-8").splitlines()
        out = []
        for line in reversed(lines[-n:]):
            try: out.append(json.loads(line))
            except: continue
        return out
    except: return []

def _bolt_recent_hearts(n: int) -> List[Dict[str, Any]]:
    if not BOLT_HEART_DIR.exists(): return []
    files = sorted(BOLT_HEART_DIR.glob("HEART_EXTRACT_*.md"), key=lambda p: p.stat().st_mtime, reverse=True)[:n]
    out = []
    for f in files:
        mtime_iso = datetime.fromtimestamp(f.stat().st_mtime).isoformat()
        out.append({
            "name": f.name,
            "size_bytes": f.stat().st_size,
            "mtime": mtime_iso,
            "preview": f.read_text(encoding="utf-8")[:200] if f.stat().st_size < 10000 else "(large file)"
        })
    return out

def _build_bolt_snapshot() -> Dict[str, Any]:
    state = _bolt_controller_state()
    cmdlog = _bolt_recent_cmdlog(20)
    hearts = _bolt_recent_hearts(5)
    
    # 1. Lineage Gate Derivation
    boot_status, boot_status_reason = _derive_bolt_boot_status()

    # 2. Preserve v1.7 Runtime Logic
    lock = state.get("lock", {})
    lock_pid = lock.get("pid") if isinstance(lock, dict) else None
    governor_active = bool(state.get("governor_active", False))
    last_seen = state.get("controller_last_seen_utc", None)
    target_url = state.get("current_target_url", None)

    if lock_pid:
        controller_status = "running"
    elif last_seen:
        controller_status = "stale"
    else:
        controller_status = "unknown"

    receipt = _read_markdown_kv(BOLT_STARTUP_RECEIPT)

    return {
        "boot_status": boot_status,
        "boot_status_reason": boot_status_reason,
        "controller_status": controller_status,
        "controller_pid": lock_pid,
        "governor_active": governor_active,
        "target_url": target_url,
        "last_seen_utc": last_seen,
        "last_heart_bundle": state.get("last_heart_bundle"),
        "last_heart_written_utc": state.get("last_heart_written_utc"),
        "inbox_index": state.get("inbox_index"),
        "startup_receipt_latest": str(BOLT_STARTUP_RECEIPT) if BOLT_STARTUP_RECEIPT.exists() else "",
        "startup_session_id": receipt.get("startup_session_id", ""),
        "startup_runtime_verified_utc": receipt.get("runtime_verified_utc", ""),
        "startup_receipt_generated_utc": receipt.get("receipt_generated_utc", ""),
        "cmdlog": cmdlog,
        "hearts": hearts,
        "state_excerpt": {
            "controller_pid": lock_pid,
            "last_heart_bundle": state.get("last_heart_bundle"),
            "last_heartbeat_utc": state.get("last_heart_written_utc"),
            "governor_active": governor_active,
            "governor_target_url": target_url
        }
    }

