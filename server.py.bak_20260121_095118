def _read_json(path: Path) -> Optional[Any]:
    try:
        if not path.exists():
            return None
        return json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        return None

def _iso_now_local() -> str:
    # Let Windows provide local offset in ISO string
    return dt.datetime.now().astimezone().isoformat(timespec="seconds")

def _latest_json_in(dir_path: Path) -> Optional[Path]:
    try:
        if not dir_path.exists():
            return None
        cands = [p for p in dir_path.glob("*.json") if p.is_file()]
        # ignore ops_signals.json
        cands = [p for p in cands if p.name.lower() != "ops_signals.json"]
        if not cands:
            return None
        cands.sort(key=lambda p: p.stat().st_mtime, reverse=True)
        return cands[0]
    except Exception:
        return None

def _ps_json(cmd: str) -> Any:
    # Returns parsed JSON (or None)
    try:
        r = subprocess.run(
            ["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", cmd],
            capture_output=True,
            text=True,
            timeout=8,
        )
        out = (r.stdout or "").strip()
        if not out:
            return None
        return json.loads(out)
    except Exception:
        return None

def _list_browser_procs() -> List[Dict[str, Any]]:
    # Keep this cheap: only the browsers we care about.
    ps = r"""
$names = @('chrome.exe','vivaldi.exe','msedge.exe','msedgewebview2.exe')
Get-CimInstance Win32_Process |
  Where-Object { $names -contains $_.Name } |
  Select-Object ProcessId, Name, ExecutablePath, CommandLine |
  ConvertTo-Json -Depth 3
""".strip()
    data = _ps_json(ps)
    if data is None:
        return []
    if isinstance(data, dict):
        return [data]
    if isinstance(data, list):
        return data
    return []

def _detect_rc1_from_procs(procs: List[Dict[str, Any]]) -> Dict[str, Any]:
    # RC1: treat ungoogled-chromium on D:\ungoogled-chromium_* as RC1
    # (this matches the process list you pasted)
    for pr in procs:
        exe = (pr.get("ExecutablePath") or pr.get("exe_path") or "").lower()
        name = (pr.get("Name") or pr.get("name") or "").lower()
        if name == "chrome.exe" and exe.startswith(r"d:\ungoogled-chromium_") and exe.endswith(r"\chrome.exe"):
            return {
                "status": "running",
                "process_id": pr.get("ProcessId") or pr.get("pid"),
                "executable_path": pr.get("ExecutablePath") or pr.get("exe_path"),
                "command_line": pr.get("CommandLine") or pr.get("cmd"),
                "detected_by": "ungoogled_chromium_path",
            }
    return {"status": "not_running"}

def _build_snapshot() -> Dict[str, Any]:
    # Prefer explicit latest file names, otherwise newest json in STATUS_DIR.
    snap_path = PRIMARY_SNAPSHOT if PRIMARY_SNAPSHOT.exists() else None
    if not snap_path and LEGACY_SNAPSHOT.exists():
        snap_path = LEGACY_SNAPSHOT
    if not snap_path:
        snap_path = _latest_json_in(STATUS_DIR)

    snap = {}
    if snap_path:
        raw = _read_json(snap_path)
        if isinstance(raw, dict):
            snap = raw

    # Normalize + enrich with ops_signals
    ops_signals = _read_json(OPS_SIGNALS_JSON)
    if isinstance(ops_signals, dict):
        snap["ops_signals"] = ops_signals

    snap.setdefault("ops_root", str(OPS_ROOT))
    snap.setdefault("timestamp", _iso_now_local())

    # RC detection override (server-side) to prevent UI lying
    procs = _list_browser_procs()
    rc1 = snap.get("rc1") if isinstance(snap.get("rc1"), dict) else {}
    rc1_status = (rc1.get("status") or "").lower() if isinstance(rc1, dict) else ""
    if rc1_status != "running":
        snap["rc1"] = _detect_rc1_from_procs(procs)

    # Keep any existing fields; add minimal telemetry fields if absent
    snap.setdefault("rc2", {"status": "unknown", "detectable": False, "expected": {"note": "RC2 not yet distinct; detection pending"}})
    snap.setdefault("rc3", {"status": "unknown"})
    snap.setdefault("renderers", {"renderer_count": 0, "renderer_pids": []})
    snap.setdefault("gpu_pipeline", {"gpu_process_count": 0, "sample_gpu_cmd": None})
    snap.setdefault("dashboard_loaded_at", dt.datetime.now().isoformat(timespec="seconds"))

    return snap

