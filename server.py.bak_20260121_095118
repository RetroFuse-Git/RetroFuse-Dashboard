<script>
  function shorten(str, max) {
    if (!str || typeof str !== "string") return "";
    if (str.length <= max) return str;
    return str.slice(0, max - 3) + "...";
  }

  function fmtBytes(n) {
    if (typeof n !== "number" || isNaN(n)) return "n/a";
    const units = ["B","KB","MB","GB","TB","PB"];
    let u = 0, v = n;
    while (v >= 1024 && u < units.length - 1) { v /= 1024; u++; }
    return v.toFixed(1) + " " + units[u];
  }

  function stripAnsi(value) {
    const s = String(value ?? "");
    return s.replace(/\\x1b\\[[0-9;]*[A-Za-z]/g, "");
  }

  function escapeHtml(value) {
    const s = stripAnsi(value);
    return s.replace(/[&<>"']/g, (c) => ({
      "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"
    }[c]));
  }

  function safeGet(obj, path, fallback = null) {
    try {
      return path.split(".").reduce((o, key) => (o && key in o ? o[key] : undefined), obj) ?? fallback;
    } catch (e) { return fallback; }
  }

  function renderOpsSignalsPills(opsSignals) {
    const ops = (opsSignals && typeof opsSignals === 'object') ? opsSignals : {};
    const order = [
      ['DailyCheck', 'DailyCheck'],
      ['CodexGate', 'CodexGate'],
      ['DailyCheckMirror', 'DailyCheckMirror'],
      ['PublisherWipeGuard', 'PublisherWipeGuard'],
    ];

    function dotClass(v) {
      const s = String(v ?? '').toLowerCase();
      if (!s) return 'warn';
      if (['success','clean','ok','true','pass','passed'].includes(s)) return 'ok';
      if (['fail','failed','bad','error','dirty'].includes(s)) return 'bad';
      return 'warn';
    }

    const pills = order.map(([label, key]) => {
      const v = ops[key];
      const cls = dotClass(v);
      const title = (v === undefined || v === null || v === '') ? 'unknown' : String(v);
      return `<span class="pill" title="${escapeHtml(title)}"><span class="pill-dot ${cls}"></span>${escapeHtml(label)}</span>`;
    });

    return `<div class="pill-row">${pills.join('')}</div>`;
  }

  async function loadSnapshot(showSpinner) {
    const snapshotCard = document.getElementById("snapshot-card");
    const snapshotMeta = document.getElementById("snapshot-meta");

    if (showSpinner && snapshotCard) {
      snapshotCard.innerHTML = '<div class="small">Refreshing snapshot...</div>';
      if (snapshotMeta) snapshotMeta.textContent = "Refreshing...";
    }

    let snapshot;
    try {
      const response = await fetch("/api/latest?nocache=" + Date.now());
      if (!response.ok) throw new Error("HTTP " + response.status);
      snapshot = await response.json();
    } catch (err) {
      if (snapshotCard) snapshotCard.innerHTML = '<div class="small" style="color:#f97373;">Failed to load snapshot.</div>';
      if (snapshotMeta) snapshotMeta.textContent = "Snapshot load failed.";
      return;
    }

    renderSnapshot(snapshot);
    renderTelemetry(snapshot);
    renderDisks(snapshot);
    renderSafepoints(snapshot);
    renderAlpha(snapshot);
    renderNotes(snapshot);
  }

  function renderSnapshot(snapshot) {
    const el = document.getElementById("snapshot-card");
    const meta = document.getElementById("snapshot-meta");
    if (!el) return;

    const tsRaw = snapshot.timestamp || "unknown";
    const ts = (tsRaw !== "unknown") ? new Date(tsRaw).toLocaleString() : "unknown";
    const opsRoot = snapshot.ops_root || "(not set)";

    const rc1 = safeGet(snapshot, "rc1.status", "unknown");
    const rc2 = safeGet(snapshot, "rc2.status", "unknown");
    const rc3 = safeGet(snapshot, "rc3.status", "unknown");

    function cls(s) {
      s = String(s||"").toLowerCase();
      if (s === "running") return "ok";
      if (s === "not_running") return "warn";
      return "bad";
    }

    el.innerHTML = `
      <div class="row"><div><div class="label">Snapshot timestamp</div><div class="value">${escapeHtml(ts)}</div></div></div>
      <div class="row"><div><div class="label">OPS root</div><div class="value mono">${escapeHtml(opsRoot)}</div></div></div>
      <div class="row">
        <div><div class="label">RC1</div><div class="value ${cls(rc1)}">${escapeHtml(rc1)}</div></div>
        <div><div class="label">RC2</div><div class="value ${cls(rc2)}">${escapeHtml(rc2)}</div></div>
        <div><div class="label">RC3</div><div class="value ${cls(rc3)}">${escapeHtml(rc3)}</div></div>
      </div>
      <div class="row">
        <div>
          <div class="label">OPS Signals</div>
          <div class="value">${renderOpsSignalsPills(snapshot.ops_signals)}</div>
        </div>
      </div>
    `;
    if (meta) meta.textContent = "Last snapshot loaded.";
  }

  function renderTelemetry(snapshot) {
    const el = document.getElementById("telemetry-card");
    if (!el) return;

    const rc1 = snapshot.rc1 || {};
    const rc2 = snapshot.rc2 || {};
    const rc3 = snapshot.rc3 || {};
    const renderers = snapshot.renderers || {};
    const gpu = snapshot.gpu_pipeline || {};

    const rc1Status = safeGet(snapshot, "rc1.status", "unknown");
    const rc2Status = safeGet(snapshot, "rc2.status", "unknown");
    const rc3Status = safeGet(snapshot, "rc3.status", "unknown");

    const pids = (v) => Array.isArray(v) ? v : (v ? [v] : []);
    const cmds = (v) => Array.isArray(v) ? v : (v ? [v] : []);

    const rc1Pids = pids(rc1.process_id || rc1.processId || rc1.pid);
    const rc2Pids = pids(rc2.process_id || rc2.processId || rc2.pid);
    const rc3Pids = pids(rc3.process_id || rc3.processId || rc3.pid);

    const rc1Cmds = cmds(rc1.command_line || rc1.commandLine || rc1.cmd);
    const rc2Cmds = cmds(rc2.command_line || rc2.commandLine || rc2.cmd);
    const rc3Cmds = cmds(rc3.command_line || rc3.commandLine || rc3.cmd);

    const rendererCount = safeGet(snapshot, "renderers.renderer_count", 0);
    const rendererPids = pids(safeGet(snapshot, "renderers.renderer_pids", []));

    const gpuCount = safeGet(snapshot, "gpu_pipeline.gpu_process_count", null);
    const gpuCmd = safeGet(snapshot, "gpu_pipeline.sample_gpu_cmd", null);

    const statusClass = (s) => {
      s = String(s||"").toLowerCase();
      if (s === "running") return "ok";
      if (s === "not_running") return "warn";
      return "bad";
    };

    const pidList = (arr) => (arr && arr.length)
      ? `<div class="list">${arr.map(p => `<div class="list-item mono">PID: ${escapeHtml(p)}</div>`).join("")}</div>`
      : `<div class="small">No PIDs recorded.</div>`;

    const cmdList = (arr) => (arr && arr.length)
      ? `<div class="list">${arr.map((c,i) => `<div class="list-item mono"><strong>Cmd ${i+1}:</strong> ${escapeHtml(shorten(c, 520))}</div>`).join("")}</div>`
      : `<div class="small">No command lines recorded.</div>`;

    const det = (title, status, pidArr, cmdArr) => `
      <div class="list-item">
        <div class="row">
          <div class="value">${escapeHtml(title)}</div>
          <div class="small ${statusClass(status)}">${escapeHtml(status)}</div>
          <div class="small" style="margin-left:auto;">${pidArr.length} PID${pidArr.length===1?"":"s"}</div>
        </div>
        <div class="label" style="margin-top:6px;">PIDs</div>
        ${pidList(pidArr)}
        <div class="label" style="margin-top:6px;">Command line(s)</div>
        ${cmdList(cmdArr)}
      </div>
    `;

    const rendererBlock = `
      <div class="list-item">
        <div class="row">
          <div class="value">Renderers</div>
          <div class="small">${escapeHtml(String(rendererCount))} renderer${rendererCount === 1 ? "" : "s"}</div>
        </div>
        ${pidList(rendererPids)}
      </div>
    `;

    const gpuBlock = `
      <div class="list-item">
        <div class="row">
          <div class="value">GPU pipeline</div>
          <div class="small">${escapeHtml(String(gpuCount ?? "?"))} GPU process${gpuCount === 1 ? "" : "es"}</div>
        </div>
        <div class="label" style="margin-top:6px;">Sample GPU command</div>
        <div class="list"><div class="list-item mono">${gpuCmd ? escapeHtml(shorten(gpuCmd, 1200)) : "n/a"}</div></div>
      </div>
    `;

    el.innerHTML = `<div class="list">
      ${det("RC1", rc1Status, rc1Pids, rc1Cmds)}
      ${det("RC2", rc2Status, rc2Pids, rc2Cmds)}
      ${det("RC3", rc3Status, rc3Pids, rc3Cmds)}
      ${rendererBlock}
      ${gpuBlock}
    </div>`;
  }

  function renderDisks(snapshot) {
    const el = document.getElementById("disks-card");
    if (!el) return;
    const disks = Array.isArray(snapshot.disks) ? snapshot.disks : [];
    if (!disks.length) { el.innerHTML = '<div class="small">No disk data found.</div>'; return; }
    el.innerHTML = `<div class="list">${disks.map(d => {
      const name = d.name || "?";
      const used = fmtBytes(d.used_bytes);
      const free = fmtBytes(d.free_bytes);
      const total = fmtBytes(d.total_bytes);
      return `<div class="list-item"><div class="row"><div class="value mono">Drive ${escapeHtml(name)}</div><div class="small">${escapeHtml(used)} used / ${escapeHtml(free)} free</div></div><div class="small">Total: ${escapeHtml(total)}</div></div>`;
    }).join("")}</div>`;
  }

  
  function renderSafepoints(snapshot) {
    const el = document.getElementById("safepoints-card");
    if (!el) return;
    const sps = Array.isArray(snapshot.safepoints) ? snapshot.safepoints : [];
    if (!sps.length) { 
      el.innerHTML = '<div class="small">No SAFEPOINT summary available.</div>'; 
      return; 
    }

    const rows = sps.map((sp, idx) => {
      const root = sp.root_path || "(unknown root)";
      const exists = sp.exists ? "yes" : "no";
      const count = (typeof sp.zip_count === "number") ? sp.zip_count : "?";
      const latest = sp.latest_zip || {};
      const latestName = latest.name || "(none)";
      const latestTime = latest.last_write || "n/a";
      const latestSize = fmtBytes(latest.size_bytes ?? 0);

      return `
        <div class="list-item">
          <div class="row">
            <div class="small">Root ${idx + 1}</div>
            <div class="small">Exists: ${escapeHtml(exists)}</div>
          </div>
          <div class="label">Root path</div>
          <div class="mono">${escapeHtml(root)}</div>
          <div class="row" style="margin-top:4px;">
            <div class="label">ZIP count</div>
            <div class="value">${escapeHtml(String(count))}</div>
          </div>
          <div class="label" style="margin-top:4px;">Latest SAFEPOINT</div>
          <div class="mono">${escapeHtml(latestName)}</div>
          <div class="small">Last write: ${escapeHtml(String(latestTime))}</div>
          <div class="small">Size: ${escapeHtml(String(latestSize))}</div>
        </div>
      `;
    }).join("");

    el.innerHTML = `<div class="list">${rows}</div>`;
  }


  function renderAlpha(snapshot) {
    const el = document.getElementById("alpha-details");
    if (!el) return;
    const alpha = snapshot.alpha || {};
    const latest = alpha.latest_file || null;
    const path = alpha.path || "(not set)";
    const exists = alpha.exists ? "yes" : "no";
    const files24 = (alpha.files_24h ?? 0);

    const latestHtml = latest
      ? `<div class="mono">${escapeHtml(latest.full_path || latest.name || JSON.stringify(latest))}</div>`
      : `<div class="small">No recorded Alpha files.</div>`;

    el.innerHTML = `
      <div class="row"><div><div class="label">Alpha path</div><div class="mono">${escapeHtml(path)}</div></div></div>
      <div class="row"><div><div class="label">Folder exists</div><div class="value">${escapeHtml(exists)}</div></div></div>
      <div class="row"><div><div class="label">Files last 24h</div><div class="value">${escapeHtml(String(files24))}</div></div></div>
      <div style="margin-top:6px;"><div class="label">Latest file</div>${latestHtml}</div>
    `;
  }

  function renderNotes(snapshot) {
    const el = document.getElementById("notes-card");
    if (!el) return;
    const notes = Array.isArray(snapshot.notes) ? snapshot.notes : [];
    if (!notes.length) { el.innerHTML = '<div class="small">No notes captured.</div>'; return; }
    el.innerHTML = `<div class="list">${notes.map(n => `<div class="list-item small">- ${escapeHtml(n)}</div>`).join("")}</div>`;
  }

  loadSnapshot(false);
</script>
</body>
</html>
"""

@app.get("/", response_class=HTMLResponse)
def index():
    return HTMLResponse(INDEX_HTML)

@app.get("/api/latest")
def api_latest():
    snap = _build_snapshot()
    return JSONResponse(snap)

@app.get("/api/latest/raw")
def api_latest_raw():
    # Alias / compat
    return api_latest()

@app.get("/_health")
def health():
    return {"status": "ok", "version": APP_VERSION}
