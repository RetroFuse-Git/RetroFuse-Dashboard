OPS_ROOT = Path(r"D:\RETROFUSE_OPS")
DASH_INPUT_JSON = Path(r"D:\RETROFUSE_OPS\Status\RFCC\OPS_Intake_Consolidated.json")
OPS_SIGNALS_PATH = Path(r"D:\RETROFUSE_OPS\Status\RFCC\OPS_Signals.json")

STALE_MINUTES_DEFAULT = 10.0

def _age_minutes(p: Path) -> float | None:
    try:
        if not p.exists():
            return None
        return (time.time() - os.path.getmtime(str(p))) / 60.0
    except Exception:
        return None

def _read_json(path: Path):
    try:
        if not path.exists():
            return None
        return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception as e:
        return {"_error": str(e)}

def _read_ops_signals():
    """
    SoftMode MinimalUI loader for OPS_Signals.json.
    Always returns a dict. Missing fields are injected with defaults.
    """
    try:
        obj = _read_json(OPS_SIGNALS_PATH)

        # If JSON missing or invalid  return diagnostics + defaults
        if not isinstance(obj, dict):
            return {
                "_ok": False,
                "_error": "OPS_Signals not a dict",
                "_raw": str(obj),
                "DailyCheck": None,            # status of daily check
                "CodexGate": None,             # codex gate status
                "DailyCheckMirror": None,      # v1v1.5 consistency
                "MirrorDiffCount": None,       # diff count
                "PublisherWipeGuard": None,    # safety flag
                "V1CreatedPresent": False,     # provenance signal
                "V1CodexGatePresent": False,   # v1 codex presence
                "V1Created": None              # timestamp of v1 run
            }

        # Inject defaults for missing keys
        obj.setdefault("DailyCheck", None)          # status of daily check
        obj.setdefault("CodexGate", None)           # codex gate status
        obj.setdefault("DailyCheckMirror", None)    # v1v1.5 consistency
        obj.setdefault("MirrorDiffCount", None)     # diff count
        obj.setdefault("PublisherWipeGuard", None)  # safety flag
        obj.setdefault("V1CreatedPresent", False)   # provenance signal
        obj.setdefault("V1CodexGatePresent", False) # v1 codex presence
        obj.setdefault("V1Created", None)           # timestamp of v1 run

        obj["_ok"] = True
        return obj

    except Exception as e:
        return {
            "_ok": False,
            "_error": str(e),
            "DailyCheck": None,
            "CodexGate": None,
            "DailyCheckMirror": None,
            "MirrorDiffCount": None,
            "PublisherWipeGuard": None,
            "V1CreatedPresent": False,
            "V1CodexGatePresent": False,
            "V1Created": None
        }

def dashboard_load_authoritative(stale_minutes: float = STALE_MINUTES_DEFAULT):
    age = _age_minutes(DASH_INPUT_JSON)
    if age is None:
        return {
            "ok": False,
            "status": "MISSING",
            "source": str(DASH_INPUT_JSON),
            "age_minutes": None,
            "message": "Dashboard input JSON not found."
        }

    data = _read_json(DASH_INPUT_JSON)
    if data is None:
        return {
            "ok": False,
            "status": "MISSING",
            "source": str(DASH_INPUT_JSON),
            "age_minutes": age,
            "message": "Dashboard input JSON missing."
        }

    if isinstance(data, dict) and age is not None and age > stale_minutes:
        data["_stale"] = True

    # Attach ops_signals always (even if missing -> None or {"_error":...})
    if isinstance(data, dict):
        try:
            data["ops_signals"] = _read_ops_signals()
            data["_ops_signals_meta"] = {
                "path": str(OPS_SIGNALS_PATH),
                "age_minutes": _age_minutes(OPS_SIGNALS_PATH)
            }
        except Exception as e:
            data["ops_signals"] = {"_error": str(e)}
            data["_ops_signals_meta"] = {"path": str(OPS_SIGNALS_PATH), "age_minutes": None}

        data["_dashboard_meta"] = {
            "ok": True,
            "source": str(DASH_INPUT_JSON),
            "age_minutes": age,
            "stale_minutes": stale_minutes
        }
    return data

