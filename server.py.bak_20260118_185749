<script>
function safeGet(obj, path, fallback){
  try{
    return path.split(".").reduce((o,k)=> (o && (k in o) ? o[k] : undefined), obj) ?? fallback;
  }catch{ return fallback; }
}
function statusClass(ok){
  if(ok === true) return "ok";
  if(ok === null || ok === undefined) return "warn";
  return "bad";
}
function sigPill(label, ok, detail){
  const cls = statusClass(ok);
  const txt = (detail && typeof detail === "string") ? detail : "";
  return `<span class="pill ${cls}"><span class="dot"></span><span class="mono">${label}</span><span class="small">${escapeHtml(txt)}</span></span>`;
}
function escapeHtml(s){
  if(!s || typeof s !== "string") return "";
  return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

async function loadSnapshot(showSpinner){
  const body = document.getElementById("body");
  const meta = document.getElementById("meta");
  const signals = document.getElementById("signals");

  if(showSpinner){
    body.innerHTML = `<div class="small">Refreshing snapshot</div>`;
    meta.textContent = "Refreshing";
    signals.innerHTML = "";
  }

  let snap;
  try{
    const u = "/api/latest?nocache=" + crypto.randomUUID();
    const r = await fetch(u);
    if(!r.ok) throw new Error("HTTP " + r.status);
    snap = await r.json();
  }catch(e){
    body.innerHTML = `<div class="small" style="color:#fb7185">Failed to load snapshot: ${escapeHtml(e.message||"unknown")}</div>`;
    meta.textContent = "Snapshot load failed.";
    return;
  }

  renderSnapshot(snap);
  renderSignals(snap);
}

function renderSignals(snap){
  const signals = document.getElementById("signals");
  const s = snap && snap.ops_signals ? snap.ops_signals : null;

  // Accept both schemas:
  // (A) nested:  DailyCheck: {status:"success"}
  // (B) flat:    DailyCheck: "success"
  function pickStatus(key){
    const nested = safeGet(s, key + ".status", undefined);
    if(nested !== undefined) return nested;
    return safeGet(s, key, null);
  }

  const dcOk  = pickStatus("DailyCheck");
  const cxOk  = pickStatus("CodexGate");
  const mirOk = pickStatus("DailyCheckMirror");
  const wpgOk = pickStatus("PublisherWipeGuard");

  const dcD = "DailyCheck=" + (dcOk ?? "missing");
  const cxD = "CodexGate=" + (cxOk ?? "missing");
  const miD = "Mirror=" + (mirOk ?? "missing");
  const wpD = "WipeGuard=" + (wpgOk ?? "missing");

  function norm(v){
    if(v === true || v === false) return v;
    if(typeof v !== "string") return null;
    const t = v.toLowerCase();
    if(["pass","success","ok","green","clean"].includes(t)) return true;
    if(["fail","error","red","bad"].includes(t)) return false;
    return null;
  }

  signals.innerHTML = [
    sigPill("DC",  norm(dcOk),  dcD),
    sigPill("CX",  norm(cxOk),  cxD),
    sigPill("MIR", norm(mirOk), miD),
    sigPill("WPG", norm(wpgOk), wpD),
  ].join("");
}

function renderSnapshot(snap){
  const body = document.getElementById("body");
  const meta = document.getElementById("meta");

  const ts = safeGet(snap, "timestamp", safeGet(snap, "created", "unknown"));
  const opsRoot = safeGet(snap, "ops_root", "(not set)");
  const okMeta = safeGet(snap, "_dashboard_meta.ok", true);
  const ageMin = safeGet(snap, "_dashboard_meta.age_minutes", null);
  const stale = safeGet(snap, "_stale", false);

  const rc1 = safeGet(snap, "rc1.status", "unknown");
  const rc2 = safeGet(snap, "rc2.status", "unknown");
  const rc3 = safeGet(snap, "rc3.status", "unknown");

  function cls(s){
    if(s === "running") return "mono";
    return "mono";
  }

  body.innerHTML = `
    <div class="k">Timestamp</div><div class="v mono">${escapeHtml(String(ts))}</div>
    <div class="k">OPS root</div><div class="v mono">${escapeHtml(String(opsRoot))}</div>
    <div class="k">RC1</div><div class="v ${cls(rc1)}">${escapeHtml(String(rc1))}</div>
    <div class="k">RC2</div><div class="v ${cls(rc2)}">${escapeHtml(String(rc2))}</div>
    <div class="k">RC3</div><div class="v ${cls(rc3)}">${escapeHtml(String(rc3))}</div>
  `;

  let m = "Loaded.";
  if(okMeta === false) m = "Not OK.";
  if(stale) m = "STALE snapshot.";
  if(ageMin !== null && ageMin !== undefined) m += " age=" + ageMin.toFixed(1) + "m";
  meta.textContent = m;
}

loadSnapshot(false);
</script>
