@app.get("/api/latest", response_class=JSONResponse)
async def api_latest() -> JSONResponse:
    """
    Return the newest DailyCheck_*.json snapshot, decoded with utf-8-sig
    to handle BOM safely.
    """
    if not STATUS_DIR.exists():
        return JSONResponse(
            {"error": f"Status directory not found: {STATUS_DIR}"},
            status_code=404,
        )


@app.get("/api/latest_full")
async def api_latest_full():
    # full snapshot payload (can be large)
    data = _load_latest_snapshot()
    return JSONResponse(data)
    files = sorted(STATUS_DIR.glob("DailyCheck_*.json"), key=lambda p: p.stat().st_mtime)
    if not files:
        return JSONResponse(
            {"error": "No DailyCheck_*.json snapshots found."},
            status_code=404,
        )

    latest = files[-1]

    try:
        text = latest.read_text(encoding="utf-8-sig")
        data = json.loads(text)
    except Exception as exc:
        return JSONResponse(
            {
                "error": f"Failed to parse {latest.name} as JSON",
                "detail": str(exc),
            },
            status_code=500,
        )

    data.setdefault("dashboard_loaded_at", dt.datetime.now().isoformat())
    return JSONResponse(data)


@app.get("/api/latest")
def api_latest(full: int = 0):
    # Latest RFCC DailyCheck snapshot (BOM-safe)
    p = Path(r"D:\RETROFUSE_OPS\Status\RFCC")
    files = sorted(p.glob("DailyCheck_*.json"), key=lambda x: x.stat().st_mtime, reverse=True)
    if not files:
        return {"ok": False, "error": "No DailyCheck_*.json found", "path": str(p)}

    f = files[0]
    try:
        data = json.loads(f.read_text(encoding="utf-8-sig"))
    except Exception as e:
        return {"ok": False, "error": str(e), "file": f.name}

    if full:
        return {"ok": True, "file": f.name, "data": data}

    g  = data.get("gpu_pipeline", {}) or {}
    r  = data.get("renderers", {}) or {}
    rc1 = data.get("rc1", {}) or {}
    rc3 = data.get("rc3", {}) or {}
    sp = data.get("safepoints", []) or []

    return {
        "ok": True,
        "file": f.name,
        "timestamp": data.get("timestamp"),
        "rc1": {"status": rc1.get("status"), "process_id": rc1.get("process_id")},
        "rc3": {"status": rc3.get("status"), "process_id": rc3.get("process_id")},
        "renderers": r,
        "gpu_process_count": g.get("gpu_process_count"),
        "latest_safepoint": (sp[0].get("latest_zip") if sp else None),
    }

