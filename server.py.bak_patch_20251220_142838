app = FastAPI(title="RetroFuse OPS Dashboard v1.4")

from pathlib import Path
import json

@app.get("/api/latest")
def api_latest():
    p = Path(r"D:\RETROFUSE_OPS\Status\RFCC")
    files = sorted(p.glob("DailyCheck_*.json"), key=lambda x: x.stat().st_mtime, reverse=True)

    if not files:
        return {"ok": False, "error": "No DailyCheck files found"}

    f = files[0]
    data = json.loads(f.read_text(encoding="utf-8-sig"))

    return {
        "ok": True,
        "file": f.name,
        "timestamp": data.get("timestamp"),
        "rc1": data.get("rc1", {}).get("status"),
        "rc3": data.get("rc3", {}).get("status"),
        "renderers": data.get("renderers", {}).get("renderer_count"),
        "gpu_processes": data.get("gpu_pipeline", {}).get("gpu_process_count"),
    }


