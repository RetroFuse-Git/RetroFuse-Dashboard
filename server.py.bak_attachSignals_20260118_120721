@app.get("/api/latest_full", response_class=JSONResponse)
async def api_latest_full() -> JSONResponse:
    """
    Return the newest DailyCheck_*.json payload (full, BOM-safe).
    """
    if not STATUS_DIR.exists():
        return JSONResponse(
            {"ok": False, "error": "Status directory not found", "path": str(STATUS_DIR)},
            status_code=404,
        )

    latest = STATUS_DIR / "DailyCheck_Latest.json"

    if latest.exists():
        files = [latest]
    else:
        files = sorted(
            STATUS_DIR.glob("DailyCheck_*.json"),
            key=lambda p: p.stat().st_mtime,
            reverse=True,
        )

    if not files:
        return JSONResponse(
            {"ok": False, "error": "No DailyCheck_*.json snapshots found.", "path": str(STATUS_DIR)},
