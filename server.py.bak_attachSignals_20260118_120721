# Canonical dashboard input (authoritative)
import os, json, time
DASH_INPUT_JSON = r"D:\RETROFUSE_OPS\Status\RFCC\DailyCheck_Latest.json"
DASH_STALE_MAX_MINUTES = 180

def _dash_age_minutes(p):
    try:
        return (time.time() - os.path.getmtime(p)) / 60.0
    except Exception:
        return None

def dashboard_load_authoritative():
    # Never silently serve stale/missing; always return explicit state.
    p = DASH_INPUT_JSON
    age = _dash_age_minutes(p)
    if (age is None) or (age > DASH_STALE_MAX_MINUTES):
        return {
            "ok": False,
            "status": "STALE",
            "reason": "missing_or_stale_input",
            "input_path": p,
            "age_minutes": age
        }
    try:
        with open(p, "r", encoding="utf-8") as f:
            obj = json.load(f)
        obj["_dashboard_input_path"] = p
        obj["_dashboard_age_minutes"] = age
        return obj
    except Exception as e:
        return {
            "ok": False,
            "status": "STALE",
            "reason": "json_parse_error",
            "input_path": p,
            "age_minutes": age,
            "error": str(e)
        }
