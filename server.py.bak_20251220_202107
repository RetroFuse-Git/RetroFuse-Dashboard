from fastapi.responses import JSONResponse

@app.get("/api/latest_full")
async def api_latest_full():
    """
    Return the newest DailyCheck_*.json payload (BOM-safe) from Status/RFCC.
    """
    import json
    files = sorted(STATUS_DIR.glob("DailyCheck_*.json"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not files:
        return JSONResponse({"ok": False, "error": "No DailyCheck_*.json snapshots found.", "path": str(STATUS_DIR)}, status_code=404)
    latest = files[0]
    with open(latest, "r", encoding="utf-8-sig") as f:
        data = json.load(f)
    return {"ok": True, "file": latest.name, "data": data}
