  <script>
    function shorten(str, max) {
      if (!str || typeof str !== "string") return "";
      if (str.length <= max) return str;
      return str.slice(0, max - 3) + "...";
    }

    function fmtBytes(n) {
      if (typeof n !== "number" || isNaN(n)) return "n/a";
      const units = ["B", "KB", "MB", "GB", "TB", "PB"];
      let u = 0;
      let v = n;
      while (v >= 1024 && u < units.length - 1) {
        v /= 1024;
        u++;
      }
      return v.toFixed(1) + " " + units[u];
    }

    function safeGet(obj, path, fallback = null) {
      try {
        return path.split(".").reduce((o, key) => (o && key in o ? o[key] : undefined), obj) ?? fallback;
      } catch {
        return fallback;
      }
    }

    function setStatusPill(el, status) {
      if (!el) return;
      const s = (status || "unknown").toString().toLowerCase();
      el.textContent = "status: " + s;
    }

    async function loadSnapshot(showSpinner) {
      const snapshotCard = document.getElementById("snapshot-card");
      const snapshotMeta = document.getElementById("snapshot-meta");

      if (showSpinner && snapshotCard) {
        snapshotCard.innerHTML = '<div class="small">Refreshing snapshot…</div>';
        if (snapshotMeta) snapshotMeta.textContent = "Refreshing…";
      }

      let snapshot;
      try {
        const response = await fetch("/api/latest?nocache=" + Date.now());
        if (!response.ok) throw new Error("HTTP " + response.status);
        snapshot = await response.json();
      } catch (err) {
        if (snapshotCard) {
          snapshotCard.innerHTML =
            '<div class="small" style="color: #f97373;">Failed to load snapshot: ' +
            (err && err.message ? err.message : "Unknown error") +
            "</div>";
        }
        if (snapshotMeta) snapshotMeta.textContent = "Snapshot load failed.";
        return;
      }

      renderSnapshot(snapshot);
      renderTelemetry(snapshot);
      renderDisks(snapshot);
      renderSafepoints(snapshot);
      renderAlpha(snapshot);
      renderNotes(snapshot);
    }

    function renderSnapshot(snapshot) {
      const snapshotCard = document.getElementById("snapshot-card");
      const snapshotMeta = document.getElementById("snapshot-meta");
      if (!snapshotCard) return;

      const ts = snapshot.timestamp || "unknown";
      const opsRoot = snapshot.ops_root || "(not set)";
      const rc1Status = safeGet(snapshot, "rc1.status", "unknown");
      const rc3Status = safeGet(snapshot, "rc3.status", "unknown");

      const rc1Color =
        rc1Status === "running" ? "value-ok" :
        rc1Status === "not_running" ? "value-warn" :
        "value-bad";

      const rc3Color =
        rc3Status === "running" ? "value-ok" :
        rc3Status === "not_running" ? "value-warn" :
        "value-bad";

      snapshotCard.innerHTML = `
        <div class="card-row">
          <div>
            <div class="label">Snapshot timestamp</div>
            <div class="value">${ts}</div>
          </div>
        </div>
        <div class="card-row">
          <div>
            <div class="label">OPS root</div>
            <div class="value mono">${opsRoot}</div>
          </div>
        </div>
        <div class="card-row">
          <div>
            <div class="label">RC1 (Bolt RC1)</div>
            <div class="value ${rc1Color}">${rc1Status}</div>
          </div>
          <div>
            <div class="label">RC3 (Bolt RC3)</div>
            <div class="value ${rc3Color}">${rc3Status}</div>
          </div>
        </div>
      `;

      if (snapshotMeta) snapshotMeta.textContent = "Last snapshot loaded.";
    }

    function renderTelemetry(snapshot) {
      const rc1Details = document.getElementById("rc1-details");
      const rc3Details = document.getElementById("rc3-details");
      const rc1Pill = document.getElementById("rc1-status-pill");
      const rc3Pill = document.getElementById("rc3-status-pill");
      const rendererSummary = document.getElementById("renderer-summary");
      const rendererDetails = document.getElementById("renderer-details");
      const gpuSummary = document.getElementById("gpu-summary");
      const gpuDetails = document.getElementById("gpu-details");

      const rc1 = snapshot.rc1 || {};
      const rc3 = snapshot.rc3 || {};
      const renderers = snapshot.renderers || {};
      const gpu = snapshot.gpu_pipeline || {};

      const rc1Status = rc1.status || "unknown";
      const rc1Pids = Array.isArray(rc1.process_id) ? rc1.process_id :
                      rc1.process_id ? [rc1.process_id] : [];
      const rc1Cmds = Array.isArray(rc1.command_line) ? rc1.command_line :
                      rc1.command_line ? [rc1.command_line] : [];

      if (rc1Pill) setStatusPill(rc1Pill, rc1Status);

      if (rc1Details) {
        if (!rc1Status && rc1Pids.length === 0) {
          rc1Details.innerHTML = '<div class="small">No RC1 data in this snapshot.</div>';
        } else {
          const pidList = rc1Pids
            .map(pid => `<span class="list-item mono">PID: ${pid}</span>`)
            .join("");

          const cmdList = rc1Cmds
            .map((cmd, idx) => `<div class="list-item mono"><strong>Command ${idx + 1}:</strong> ${shorten(cmd, 260)}</div>`)
            .join("");

          rc1Details.innerHTML = `
            <div class="card-row">
              <div>
                <div class="label">Status</div>
                <div class="value">${rc1Status}</div>
              </div>
              <div>
                <div class="label">Process count</div>
                <div class="value">${rc1Pids.length}</div>
              </div>
            </div>
            <div class="label">PIDs</div>
            <div class="list">
              ${pidList || '<div class="small">No PIDs recorded.</div>'}
            </div>
            <div class="label" style="margin-top:4px;">Command line(s)</div>
            <div class="list">
              ${cmdList || '<div class="small">No command-line data recorded.</div>'}
            </div>
          `;
        }
      }

      const rc3Status = rc3.status || "unknown";
      const rc3Pids = Array.isArray(rc3.process_id) ? rc3.process_id :
                      rc3.process_id ? [rc3.process_id] : [];
      const rc3Cmds = Array.isArray(rc3.command_line) ? rc3.command_line :
                      rc3.command_line ? [rc3.command_line] : [];

      if (rc3Pill) setStatusPill(rc3Pill, rc3Status);

      if (rc3Details) {
        if (!rc3Status && rc3Pids.length === 0) {
          rc3Details.innerHTML = '<div class="small">No RC3 data in this snapshot.</div>';
        } else {
          const pidList = rc3Pids
            .map(pid => `<span class="list-item mono">PID: ${pid}</span>`)
            .join("");

          const cmdList = rc3Cmds
            .map((cmd, idx) => `<div class="list-item mono"><strong>Command ${idx + 1}:</strong> ${shorten(cmd, 260)}</div>`)
            .join("");

          rc3Details.innerHTML = `
            <div class="card-row">
              <div>
                <div class="label">Status</div>
                <div class="value">${rc3Status}</div>
              </div>
              <div>
                <div class="label">Process count</div>
                <div class="value">${rc3Pids.length}</div>
              </div>
            </div>
